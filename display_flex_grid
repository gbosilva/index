--//--//--//--//--//--//--//--//--//--//--//--// CREACION DE LA GRID
grid-template-columns: Establece el numero y tamaño de columnas a crear
	50px 300px	- 2 columnas, una de 50 px y otra de 300px
	1fr 2fr		- 2 columnas, una de 1 fraccion y la otra de 2 fracciones
	repeat(2, 50px)	- 2 columnas de 50px
	1fr repeat(2, 50px 100px) 2fr - 4 columnas, 1 de 1 fraccion, una de 50px, otra de 100px y la ultima de 2 fracciones
	
grid-template-rows: Establece el numero y tamaño de filas a crear
	Mismas caracteristicas

